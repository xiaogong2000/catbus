#!/usr/bin/env bash
set -euo pipefail
REGISTRY="/opt/catbus/registry"
echo "🚌 已注册机器人："
shopt -s nullglob
files=("$REGISTRY"/*.json)
if [ ${#files[@]} -eq 0 ]; then
    echo "  (无)"
    exit 0
fi
for f in "${files[@]}"; do
    name=$(basename "$f" .json)
    created=$(python3 -c "import json;print(json.load(open('$f'))['created'])" 2>/dev/null || echo "?")
    echo "  🤖 $name  (注册于 $created)"
done
